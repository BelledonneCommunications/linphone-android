<resources>
    <style name="AppSplashScreenTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bc_white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/linphone_splashscreen</item>
        <item name="postSplashScreenTheme">@style/Theme.Linphone</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.Linphone" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- https://developer.android.com/guide/topics/display-cutout#best_practices_for_display_cutout_support -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- Customize your theme here. -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowBackground">@color/bc_white</item>
        <item name="android:statusBarColor">?attr/color_main1_500</item>

        <item name="color_main1_100">@color/orange_main_100</item>
        <item name="color_main1_500">@color/orange_main_500</item>

        <item name="color_main2_000">@color/bc_white</item>
        <item name="color_main2_100">@color/gray_main2_100</item>
        <item name="color_main2_200">@color/gray_main2_200</item>
        <item name="color_main2_300">@color/gray_main2_300</item>
        <item name="color_main2_400">@color/gray_main2_400</item>
        <item name="color_main2_500">@color/gray_main2_500</item>
        <item name="color_main2_600">@color/gray_main2_600</item>
        <item name="color_main2_700">@color/gray_main2_700</item>
        <item name="color_main2_800">@color/gray_main2_800</item>
        <item name="color_main2_900">@color/bc_black</item>

        <item name="color_grey_100">@color/gray_100</item>
        <item name="color_grey_200">@color/gray_200</item>
        <item name="color_grey_300">@color/gray_300</item>
        <item name="color_grey_400">@color/gray_400</item>
        <item name="color_grey_500">@color/gray_500</item>
        <item name="color_grey_600">@color/gray_600</item>
        <item name="color_grey_800">@color/gray_800</item>
        <item name="color_grey_900">@color/gray_900</item>

        <item name="color_danger_500">@color/red_danger_500</item>
        <item name="color_danger_700">@color/red_danger_700</item>
        <item name="color_danger_900">@color/red_danger_900</item>

        <item name="color_success_200">@color/green_success_200</item>
        <item name="color_success_500">@color/green_success_500</item>
        <item name="color_success_700">@color/green_success_700</item>

        <item name="color_info_500">@color/blue_info_500</item>

        <item name="color_warning_600">@color/orange_warning_600</item>
        <item name="color_plain_text_security_warning_600">@color/orange_plain_text_security_warning_600</item>

        <item name="color_on_main">@color/bc_white</item>
        <item name="color_background_contrast_in_dark_mode">@color/bc_white</item>
        <item name="color_separator">@color/gray_main2_200</item>
        <item name="color_text">@color/gray_main2_600</item>
        <item name="color_hint_text">@color/gray_main2_400</item>

        <item name="color_text_field_background">@color/gray_100</item>
        <item name="color_avatar_background">@color/gray_main2_200</item>
        <item name="color_avatar_text">@color/gray_main2_600</item>

        <item name="color_chat_bubble_incoming">@color/gray_main2_100</item>
        <item name="color_chat_bubble_outgoing">@color/orange_main_100</item>
        <item name="color_chat_bubble_reply">@color/gray_200</item>
        <item name="color_chat_bubble_file">@color/gray_main2_200</item>

        <item name="color_message_text_field_background">@color/bc_white</item>
        <item name="color_conversation_send_area_background">@color/gray_100</item>

        <item name="color_button_background">@color/gray_main2_200</item>
        <item name="color_button_pressed_background">@color/gray_main2_300</item>
        <item name="color_button_disabled_background">@color/gray_200</item>

        <item name="color_gradient_start">@color/gray_main2_100</item>
        <item name="color_gradient_end">@color/bc_white</item>

        <item name="color_trust_background">@color/gray_main2_100</item>
        <item name="color_trust_track">@color/blue_info_500</item>

        <item name="color_bottom_sheet_handle">@color/gray_main2_300</item>
        <item name="color_bottom_sheet_background">@color/gray_100</item>

        <item name="color_bottom_sheet_disabled_menu">@color/gray_200</item>
    </style>

